generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id            String             @id @default(uuid())
  name          String
  slug          String             @unique
  aiEnabled     Boolean            @default(false)
  openaiApiKey  String?
  settingsJson  String?
  users         User[]
  customers     Customer[]
  attendants    Attendant[]
  botConnections BotConnection[]
  conversations Conversation[]
  categories    Category[]
  knowledgeItems KnowledgeItem[]
  aiSuggestions AiSuggestion[]
  settingsRecords Setting[]
  embeddings    Embedding[]
  auditLogs     AuditLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model User {
  id             String    @id @default(uuid())
  company        Company   @relation(fields: [companyId], references: [id])
  companyId      String
  name           String
  email          String    @unique
  password       String
  role           String    @default("ATTENDANT")
  whatsappAccess Boolean   @default(false)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  auditLogs      AuditLog[]
}

model Customer {
  id          String        @id @default(uuid())
  company     Company       @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  phone       String
  externalId  String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  conversations Conversation[]
}

model Attendant {
  id          String        @id @default(uuid())
  company     Company       @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  externalId  String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  conversations Conversation[]
}

model BotConnection {
  id          String             @id @default(uuid())
  company     Company            @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  apiUrl      String
  token       String
  type        String
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Conversation {
  id             String       @id @default(uuid())
  company        Company      @relation(fields: [companyId], references: [id])
  companyId      String
  externalId     String       @unique
  customer       Customer?    @relation(fields: [customerId], references: [id])
  customerId     String?
  attendant      Attendant?   @relation(fields: [attendantId], references: [id])
  attendantId    String?
  status         String       @default("OPEN")
  subject        String?
  messages       Message[]
  knowledgeItems KnowledgeItem[]
  aiSuggestions  AiSuggestion[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Message {
  id             String      @id @default(uuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         String
  body           String
  messageType    String
  direction      String
  timestamp      DateTime
  attachments    Attachment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Attachment {
  id          String    @id @default(uuid())
  message     Message   @relation(fields: [messageId], references: [id])
  messageId   String
  url         String
  filename    String?
  mimeType    String?
  createdAt   DateTime  @default(now())
}

model Category {
  id          String       @id @default(uuid())
  company     Company      @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  createdAt   DateTime     @default(now())
  knowledgeItems KnowledgeItem[]

  @@unique([companyId, name])
}

model KnowledgeItem {
  id                  String      @id @default(uuid())
  company             Company     @relation(fields: [companyId], references: [id])
  companyId           String
  title               String
  answer              String
  category            Category?   @relation(fields: [categoryId], references: [id])
  categoryId          String?
  confidence          Float       @default(0.0)
  sourceConversation  Conversation? @relation(fields: [sourceConversationId], references: [id])
  sourceConversationId String?
  approved            Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model AiSuggestion {
  id             String       @id @default(uuid())
  company        Company      @relation(fields: [companyId], references: [id])
  companyId      String
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?
  suggestion     String
  confidence     Float        @default(0.0)
  createdAt      DateTime     @default(now())
}

model Embedding {
  id          String    @id @default(uuid())
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String
  sourceType  String
  sourceId    String
  content     String
  vectorJson  String
  createdAt   DateTime  @default(now())
}

model Setting {
  id          String    @id @default(uuid())
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String
  key         String
  value       String
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String    @id @default(uuid())
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?
  action      String
  details     String?
  createdAt   DateTime  @default(now())
}
